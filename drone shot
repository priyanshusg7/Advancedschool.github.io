<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Future School 2040</title>

<style>
body {
  margin: 0;
  height: 200vh;
  background: black;
  overflow-x: hidden;
  font-family: 'Segoe UI', sans-serif;
}

/* VIDEO */
video {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.75);
}

/* SCROLL HINT */
.scroll-hint {
  position: fixed;
  bottom: 40px;
  width: 100%;
  text-align: center;
  color: #ff2e63;
  font-size: 1.2rem;
  animation: fade 1.5s infinite alternate;
}

@keyframes fade {
  from { opacity: 0.3; }
  to { opacity: 1; }
}

/* OVERLAY */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at center, #1a1a2e, #0f0c29);
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: white;
  opacity: 0;
  transition: 1s ease;
}

/* TITLE */
.title {
  font-size: 3rem;
  margin-bottom: 40px;
  color: #ff2e63;
  text-shadow:
    0 0 10px #ff2e63,
    0 0 20px #ff2e63,
    0 0 40px #9d4edd;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0); }
}

/* BUTTONS */
.buttons {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: center;
}

/* BUTTON STYLE */
button {
  padding: 12px 24px;
  border: 1px solid #ff2e63;
  background: transparent;
  color: #ff2e63;
  font-size: 16px;
  cursor: pointer;
  border-radius: 10px;
  transition: 0.3s;
  box-shadow: 0 0 10px rgba(255, 46, 99, 0.3);
  opacity: 0;
  transform: translateY(20px);
}

/* HOVER */
button:hover {
  background: #ff2e63;
  color: white;
  box-shadow:
    0 0 10px #ff2e63,
    0 0 20px #ff2e63,
    0 0 40px #9d4edd;
  transform: translateY(-5px) scale(1.07);
}

/* SHOW ANIMATION */
button.show {
  opacity: 1;
  transform: translateY(0);
}

/* LINK RESET */
a {
  text-decoration: none;
}

/* FADE OUT PAGE */
.fade-out {
  animation: fadeOut 0.6s forwards;
}

@keyframes fadeOut {
  to {
    opacity: 0;
    transform: scale(1.05);
  }
}
</style>
</head>

<body>

<video id="video" src="lol/kkj.mp4" muted playsinline preload="auto"></video>

<div class="scroll-hint" id="hint">Scroll to begin ↓</div>

<div class="overlay" id="overlay">
  <div class="title">Welcome to Our School</div>

  <div class="buttons">
    <a href="classroom.html"><button>Classroom</button></a>
    <a href="labs.html"><button>Labs</button></a>
    <a href="transport.html"><button>Transport</button></a>
    <a href="sports.html"><button>Sports</button></a>
  </div>
</div>

<script>
const video = document.getElementById("video");
const hint = document.getElementById("hint");
const overlay = document.getElementById("overlay");
const buttons = document.querySelectorAll("button");

let started = false;

/* START VIDEO */
window.addEventListener("scroll", () => {
  if (!started) {
    video.play();
    hint.style.opacity = 0;
    started = true;
  }
});

/* SHOW UI */
video.addEventListener("ended", () => {
  overlay.style.opacity = 1;

  buttons.forEach((btn, i) => {
    setTimeout(() => {
      btn.classList.add("show");
    }, i * 200);
  });
});

/* SMOOTH PAGE TRANSITION */
document.querySelectorAll("a").forEach(link => {
  link.addEventListener("click", function(e) {
    e.preventDefault();
    const href = this.getAttribute("href");

    document.body.classList.add("fade-out");

    setTimeout(() => {
      window.location.href = href;
    }, 500);
  });
});
</script>

</body>
</html>